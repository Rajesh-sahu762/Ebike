<%@ Master Language="C#" 
    AutoEventWireup="true"
    CodeFile="ClientMaster.master.cs"
    Inherits="Client_ClientMaster"
    EnableViewState="false" %>
<!DOCTYPE html>
<html>
<head id="Head1" runat="server">
    <title>EBikes Duniya</title>

    <!-- ✅ Main SVG Favicon (sabse best - sab browsers mein kaam karta hai) -->
<link rel="icon" type="image/svg+xml" 
      href="<%= ResolveUrl("~/Uploads/favicon/favicon-ebd.svg") %>" />

<!-- ✅ Fallback PNG for purane browsers -->
<link rel="icon" type="image/png" sizes="32x32" 
      href="<%= ResolveUrl("~/Uploads/favicon/favicon-32x32.png") %>" />
<link rel="icon" type="image/png" sizes="16x16" 
      href="<%= ResolveUrl("~/Uploads/favicon/favicon-16x16.png") %>" />

<!-- ✅ iPhone/iPad home screen icon -->
<link rel="apple-touch-icon" sizes="180x180" 
      href="<%= ResolveUrl("~/Uploads/favicon/favicon-180x180.png") %>" />

<!-- ✅ Browser tab color (orange theme) -->
<meta name="theme-color" content="#F45B00" />
   <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>




<style>


