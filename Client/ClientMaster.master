<style>
    /* Footer Styling - Clean & Professional */
    .f-title { 
        color: #f0f4ff; 
        font-size: 16px; 
        font-weight: 700; 
        margin-bottom: 22px; 
        position: relative;
    }
    .f-title::after {
        content: '';
        display: block;
        width: 25px;
        height: 2px;
        background: #ff6b35;
        margin-top: 8px;
    }
    .f-ul { list-style: none; padding: 0; margin: 0; }
    .f-ul li { margin-bottom: 12px; }
    .f-ul a { 
        color: #8899bb; 
        text-decoration: none; 
        font-size: 14px; 
        transition: all 0.3s ease; 
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .f-ul a i { font-size: 12px; color: #334155; transition: 0.3s; }
    .f-ul a:hover { color: #ff6b35; padding-left: 5px; }
    .f-ul a:hover i { color: #ff6b35; }

    .f-social-btn {
        width: 36px; height: 36px; border-radius: 8px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.08);
        display: flex; align-items: center; justify-content: center;
        color: #8899bb; text-decoration: none; transition: 0.3s;
    }
    .f-social-btn:hover { background: #ff6b35; color: white; border-color: #ff6b35; transform: translateY(-3px); }

    .f-contact-info p { font-size: 13.5px; margin-bottom: 8px; display: flex; align-items: center; gap: 10px; color: #8899bb; }

    .f-legal { color: #475569; text-decoration: none; transition: 0.2s; }
    .f-legal:hover { color: #ff6b35; }

    @media (max-width: 768px) {
        .footer-grid { text-align: center; }
        .footer-col { display: flex; flex-direction: column; align-items: center; }
        .f-ul a { justify-content: center; }
        .f-title::after { margin: 8px auto 0; }
    }
</style>

</form>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>



<div id="floatingCart">
    <a href="Cart.aspx" class="cart-link group">
        <div style="position: relative;">
            <i class="fas fa-bag-shopping" style="font-size: 20px;"></i>
            <span id="floatingCount" class="badge-count" style="top: -8px; right: -8px; border: 2px solid #0f172a;">0</span>
        </div>
        <div style="padding-right: 8px;">
            <p style="font-[10px]; font-weight: bold; text-transform: uppercase; color: #94a3b8; margin:0; line-height:1;">View Cart</p>
            <p style="font-weight: 900; font-size: 14px; margin:0; color: white;">Proceed to Order</p>
        </div>
        <i class="fas fa-arrow-right" style="font-size: 12px;"></i>
    </a>
</div>

<script>
    function updateCartUI(newCount) {
        var count = parseInt(newCount) || 0;
        var floatBtn = document.getElementById('floatingCart');
        var floatCount = document.getElementById('floatingCount');

        if (floatBtn && floatCount) {
            floatCount.innerText = count;

            if (count > 0) {
                // Pehle block karo fir animation ke liye class add karo
                floatBtn.style.display = 'block';
                setTimeout(function () {
                    floatBtn.classList.add('active');
                }, 10);
            } else {
                floatBtn.classList.remove('active');
                setTimeout(function () {
                    floatBtn.style.display = 'none';
                }, 500);
            }
        }
    }
</script>



<script>
    /* ═══════════════════════════════════════════════════════════
       EBIKES DUNIYA — CLIENTMASTER.MASTER JS
       Includes updated active nav mapping for new pages.
    ═══════════════════════════════════════════════════════════ */

    var _lastWishCount = -1;

    function updateWishCount() {
        $.ajax({
            type: "POST",
            url: "/Client/Bikes.aspx/GetWishlistCount",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (res) {
                var badge = document.getElementById("wishCount");
                if (!badge) return;
                var count = parseInt(res.d) || 0;
                badge.innerText = count;
                badge.style.display = count > 0 ? "flex" : "none";
            }
        });
    }

    document.addEventListener("DOMContentLoaded", function () {
        updateWishCount();
    });

    /* Search pill */
    var pill = document.getElementById("searchPill");
    var toggleBtn = document.getElementById("searchToggleBtn");
    var clearBtn = document.getElementById("searchClearBtn");
    var input = document.getElementById("txtSearch");
    var dropdown = document.getElementById("searchDropdown");
    var searchTimer = null;

    toggleBtn.addEventListener("click", function (e) {
        e.stopPropagation();
        if (pill.classList.contains("open")) {
            var q = input.value.trim();
            if (q.length > 0) {
                doSearch(q);
            } else {
                closePill();
            }
        } else {
            openPill();
        }
    });

    clearBtn.addEventListener("click", function (e) {
        e.stopPropagation();
        closePill();
    });

    input.addEventListener("input", function () {
        clearTimeout(searchTimer);
        var q = this.value.trim();
        if (q.length < 2) { hideDropdown(); return; }
        searchTimer = setTimeout(function () { loadSuggestions(q); }, 280);
    });

    input.addEventListener("keydown", function (e) {
        if (e.key === "Enter") {
            e.preventDefault();
            var q = this.value.trim();
            if (q) doSearch(q);
        }
        if (e.key === "Escape") closePill();
    });

    document.addEventListener("click", function (e) {
        var wrap = document.querySelector(".search-pill-wrap");
        if (wrap && !wrap.contains(e.target)) closePill();
    });

    function openPill() {
        pill.classList.add("open");
        setTimeout(function () { input.focus(); }, 180);
    }

    function closePill() {
        pill.classList.remove("open");
        input.value = "";
        hideDropdown();
    }

    function doSearch(q) {
        var base = window.location.pathname;
        var dir = base.substring(0, base.lastIndexOf("/") + 1);
        window.location.href = dir + "Bikes.aspx?search=" + encodeURIComponent(q);
    }

    function loadSuggestions(q) {
        $.ajax({
            type: "GET",
            url: window.location.pathname.split("/").slice(0, -1).join("/") +
                 "/SearchSuggestions.ashx?q=" + encodeURIComponent(q),
            dataType: "json",
            success: function (data) {
                renderSuggestions(data, q);
            },
            error: function () {
                hideDropdown();
            }
        });
    }

    function renderSuggestions(items, q) {

        if (!items || items.length === 0) {
            dropdown.innerHTML =
                '<div class="sd-no-result">No results found</div>';
            dropdown.classList.add("show");
            return;
        }

        var html = "";

        items.forEach(function (item) {

            var url = "#";

            if (item.Type === "Bike")
                url = "BikeDetails.aspx?id=" + item.ID;

            else if (item.Type === "Part")
                url = "PartDetails.aspx?id=" + item.ID;

            else if (item.Type === "Station")
                url = "ChargingStations.aspx";

            else if (item.Type === "Service")
                url = "ServiceCenters.aspx";


            var imgHtml = item.ImagePath
                ? '<img src="' + item.ImagePath + '" />'
                : '<span>⚡</span>';

            html += '<a class="sd-item" href="' + url + '">' +
                '<div class="sd-img">' + imgHtml + '</div>' +
                '<div class="sd-info">' +
                    '<div class="sd-name">' + item.Name + '</div>' +
                    '<div class="sd-brand">' + item.Type + '</div>' +
                '</div>' +
            '</a>';
        });

        dropdown.innerHTML = html;
        dropdown.classList.add("show");
    }

    function hideDropdown() {
        dropdown.classList.remove("show");
        dropdown.innerHTML = "";
    }

    function escHtml(str) {
        return String(str)
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;");
    }

    /* Mobile menu toggle */
    function toggleMenu() {
        var menu = document.getElementById("navMenu");
        var toggle = document.getElementById("menuToggle");
        var isOpen = menu.classList.toggle("show");
        toggle.innerHTML = isOpen
            ? '<i class="fa fa-xmark"></i>'
            : '<i class="fa fa-bars"></i>';
    }

    /* Mobile dropdown accordion */
    document.querySelectorAll(".dropdown").forEach(function (dd) {
        var trigger = dd.querySelector("a");
        if (!trigger) return;

        trigger.addEventListener("click", function (e) {
            if (window.innerWidth > 992) return;
            e.preventDefault();
            document.querySelectorAll(".dropdown.mob-open").forEach(function (other) {
                if (other !== dd) other.classList.remove("mob-open");
            });
            dd.classList.toggle("mob-open");
        });
    });

    document.querySelectorAll(".nav-menu a:not(.dropdown > a)").forEach(function (a) {
        a.addEventListener("click", function () {
            if (window.innerWidth <= 992) {
                document.getElementById("navMenu").classList.remove("show");
                document.getElementById("menuToggle").innerHTML = '<i class="fa fa-bars"></i>';
            }
        });
    });

    /* Active nav link mapping (updated with new pages) */
    function setActiveNavLink() {
        var page = window.location.pathname.split("/").pop().toLowerCase();

        var map = {
            "home.aspx": "lnkHome",
            "bikes.aspx": "ddBuy",
            "usedbikes.aspx": "ddBuy",
            "parts.aspx": "ddBuy",                  // Parts under Buy dropdown
            "sellbike.aspx": "lnkSell",
            "rental.aspx": "ddRent",
            "myrentals.aspx": "ddRent",
            "compare.aspx": "lnkCompare",
            "chargingstations.aspx": "ddServices",   // Charging Stations under Services
            "servicecenters.aspx": "ddServices",     // Service Centers under Services
            "myenquiries.aspx": "lnkEnquiry",
            "enquiry.aspx": "lnkEnquiry"
        };

        var targetId = map[page];
        if (!targetId) return;

        var el = document.getElementById(targetId);
        if (!el) return;

        if (el.classList.contains("dropdown")) {
            el.classList.add("active");
        } else {
            el.classList.add("active");
        }
    }

    /* Logo fallback */
    (function () {
        var logoImg = document.getElementById("imgLogo");
        var logoIcon = document.getElementById("iconFallback");
        if (!logoImg || !logoIcon) return;

        if (logoImg.src && logoImg.src !== window.location.href) {
            logoImg.style.display = "block";
            logoIcon.style.display = "none";
        }

        logoImg.onerror = function () {
            logoImg.style.display = "none";
            logoIcon.style.display = "block";
        };
    })();

    /* Sticky navbar shadow */
    window.addEventListener("scroll", function () {
        var nav = document.getElementById("ebNav");
        if (!nav) return;
        if (window.scrollY > 50) {
            nav.style.boxShadow = "0 4px 30px rgba(0,0,0,0.6), 0 1px 0 rgba(0,212,255,0.1)";
            nav.style.background = "rgba(4,10,20,0.98)";
        } else {
            nav.style.boxShadow = "";
            nav.style.background = "";
        }
    }, { passive: true });

    setActiveNavLink();
</script>

    <script>
        // Ye function ab cart count live fetch karega bina page refresh ke
        function updateLiveCartCount() {
            $.ajax({
                type: "POST",
                url: "<%= ResolveUrl("~/Client/Parts.aspx/GetCartCount") %>", // Make sure ye method Bikes.aspx.cs mein ho
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (res) {
                    var count = parseInt(res.d) || 0;

                    // 1. Header Desktop Count
                    var masterBadge = document.getElementById("cartCount");
                    if (masterBadge) masterBadge.innerText = count;

                    // 2. Floating Cart Update
                    updateCartUI(count);
                }
            });
        }

        // Page load hote hi count check karo
        document.addEventListener("DOMContentLoaded", function () {
            updateWishCount();
            updateLiveCartCount(); // Live update on load
        });
    </script>

<asp:ContentPlaceHolder ID="PageScripts" runat="server"></asp:ContentPlaceHolder>

</body>
</html>