html{scroll-behavior:smooth;}

body{
    margin:0;
    font-family:'Segoe UI';
    background:#f9fafb;
}

/* ===== PREMIUM NAVBAR ===== */

.custom-navbar{
    background: linear-gradient(90deg,#0f172a,#1e3a8a);
    padding: 15px 0;
    transition: 0.3s;
}

.navbar-brand{
    font-size:20px;
}

.nav-link{
    color:#fff !important;
    font-weight:500;
    margin-right:15px;
    position:relative;
}

.nav-link:hover{
    color:#38bdf8 !important;
}

.search-input{
    width:180px;
    border-radius:25px;
    padding:6px 15px;
    border:none;
}

.btn-glow{
    background:linear-gradient(45deg,#06b6d4,#3b82f6);
    border:none;
    color:white;
    border-radius:25px;
    padding:6px 18px;
    font-weight:600;
    transition:0.3s;
}

.btn-glow:hover{
    transform:translateY(-2px);
    box-shadow:0 6px 20px rgba(0,0,0,0.3);
}

.wishlist-badge{
    position:absolute;
    top:-8px;
    right:-10px;
    background:#ef4444;
    color:white;
    font-size:11px;
    padding:3px 6px;
    border-radius:50%;
}

/* Mobile Fix */
@media(max-width:992px){

    .search-input{
        width:100%;
        margin-bottom:10px;
    }

    .d-flex{
        flex-direction:column;
        align-items:flex-start !important;
        gap:10px;
    }

}


/* ===== CONTENT ===== */

/*.main-content{
    padding-top:100px;
    min-height:80vh;
}*/

/* ===== FOOTER ===== */
.premium-footer {
    background: #0f172a;
    color: #cbd5e1;
    padding: 80px 0 30px 0;
}

.footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit,minmax(250px,1fr));
    gap: 30px;
}
.footer-col h4,
.footer-col h5 {
    color: white;
    margin-bottom: 20px;
}

.footer-col p {
    font-size: 14px;
    line-height: 1.6;
}

.footer-col ul {
    list-style: none;
    padding: 0;
}

.footer-col ul li {
    margin-bottom: 10px;
}

.footer-col ul li a {
    text-decoration: none;
    color: #94a3b8;
    transition: 0.3s;
}

.footer-col ul li a:hover {
    color: #06b6d4;
}

.footer-input {
    width: 100%;
    padding: 10px;
    border-radius: 8px;
    border: none;
    margin-bottom: 10px;
}

.footer-btn {
    width: 100%;
    padding: 10px;
    background: linear-gradient(135deg,#06b6d4,#7c3aed);
    border: none;
    color: white;
    border-radius: 8px;
}

.footer-bottom {
    border-top: 1px solid #1e293b;
    padding-top: 20px;
    text-align: center;
    font-size: 14px;
}

/* ===== LIVE SEARCH ===== */

.search-wrapper{
    position:relative;
    width:240px;
}

.live-search-input{
    width:100%;
    padding:8px 40px 8px 15px;
    border-radius:25px;
    border:none;
    outline:none;
}

.search-btn{
    position:absolute;
    right:5px;
    top:4px;
    background:transparent;
    border:none;
    color:#0f172a;
    font-size:16px;
}

.search-dropdown{
    position:absolute;
    top:45px;
    left:0;
    width:100%;
    background:white;
    border-radius:10px;
    box-shadow:0 10px 25px rgba(0,0,0,0.15);
    max-height:300px;
    overflow-y:auto;
    display:none;
    z-index:9999;
}

.search-item{
    padding:10px;
    cursor:pointer;
    border-bottom:1px solid #eee;
}

.search-item:hover{
    background:#f1f5f9;
}

@media(max-width:992px){
    .search-wrapper{
        width:100%;
        margin-bottom:10px;
    }
}


</style>

    <style>

/* ===== TOPBAR ===== */

.topbar{
background:linear-gradient(90deg,#071a3a,#0c2a60);
color:#9fb4d6;
font-size:13px;
padding:6px 0;
border-bottom:1px solid rgba(255,255,255,0.08);
text-align:center;
position:relative;
}

.topbar strong{
color:#00d4ff;
}

.topbar a{
color:#ff6b35;
font-weight:600;
text-decoration:none;
}

.topbar a:hover{
text-decoration:underline;
}

.topbar-close{
position:absolute;
right:15px;
top:50%;
transform:translateY(-50%);
cursor:pointer;
color:#8aa0c0;
}

/* ===== NAVBAR ===== */

.eb-navbar{
background:linear-gradient(180deg,#071a2e,#020814);
border-bottom:1px solid rgba(255,255,255,0.06);
position:sticky;
top:0;
z-index:1000;
}

.nav-inner{
max-width:1250px;
margin:auto;
display:flex;
align-items:center;
justify-content:space-between;
padding:10px 18px;
}


/* LOGO */

.logo-wrap{
display:flex;
align-items:center;
gap:10px;
text-decoration:none;
}

.logo-icon{
width:36px;
height:36px;
border-radius:10px;
background:linear-gradient(135deg,#ff6b35,#e84400);
display:flex;
color:white;
align-items:center;
justify-content:center;
}

.logo-text{
display:flex;
flex-direction:column;
}

.logo-title{
font-size:16px;
font-weight:700;
color:#f0f4ff;
}

.logo-sub{
font-size:10px;
letter-spacing:2px;
color:#00d4ff;
}


/* MENU */

.nav-menu{
display:flex;
gap:20px;
align-items:center;
}

.nav-menu a{
color:#9fb4d6;
text-decoration:none;
font-size:14px;
display:flex;
gap:6px;
align-items:center;
}

.nav-menu a:hover{
color:white;
}


/* DROPDOWN */

.dropdown{
position:relative;
}

.dropdown-menu{
position:absolute;
top:40px;
left:0;
background:#071a2e;
border:1px solid rgba(255,255,255,0.05);
border-radius:8px;
display:none;
transition:2s ease-in;
flex-direction:column;
min-width:180px;
}

.dropdown:hover .dropdown-menu{
display:flex;
}

.dropdown-menu a{

padding:10px 14px;
color:#9fb4d6;
}


.dropdown-menu a:hover{
background:rgba(255,255,255,0.05);
color:white;
}


/* RIGHT */

.nav-actions{
display:flex;
align-items:center;
gap:10px;
}

.icon-btn{
width:36px;
height:36px;
text-decoration:none;
border-radius:50%;
background:rgba(255,255,255,0.05);
display:flex;
align-items:center;
justify-content:center;
color:#9fb4d6;
position:relative;
}

.icon-btn:hover{
background:rgba(255,255,255,0.1);
color:white;
}

.badge-count{
position:absolute;
top:-4px;
right:-4px;
background:#ff6b35;
font-size:10px;
padding:2px 5px;
border-radius:10px;
color:white;
}

.btn-login{
background:linear-gradient(135deg,#00d4ff,#4f8bff);
border:none;
color:#021018;
padding:8px 18px;
border-radius:20px;
font-weight:600;
text-decoration:none;
}


/* SEARCH */

.search-box{
display:none;
position:absolute;
top:60px;
right:10%;
background:#071a2e;
padding:10px;
border-radius:8px;
}

.search-box input{
background:#020814;
border:none;
padding:8px 12px;
color:white;
border-radius:6px;
}


/* MOBILE */

.menu-toggle{
display:none;
font-size:22px;
color:white;
cursor:pointer;
}

@media(max-width:992px){

.nav-menu{
display:none;
position:absolute;
top:60px;
left:0;
right:0;
background:#071a2e;
flex-direction:column;
padding:15px;
}

.nav-menu.show{
display:flex;
}

.menu-toggle{
display:block;
}

.logo-sub{
display:none;
}

}
</style>


</head>

<body>

<form id="Form1" runat="server">

  <asp:ScriptManager ID="ScriptManager1" runat="server"
    EnablePageMethods="true"
    ScriptMode="Release"
    EnablePartialRendering="true" />


<div class="topbar">

⚡ <strong>New 2026:</strong> Ather Rizta & OLA S1 X+ now listed — 
<a href="Bikes.aspx">Explore Now →</a>

<span class="topbar-close" onclick="this.parentElement.style.display='none'">
<i class="fa fa-times"></i>
</span>

</div>


   <nav class="eb-navbar">

<div class="nav-inner">

<!-- LOGO -->

<a href="Home.aspx" class="logo-wrap">

<div class="logo-icon">
<i class="fa fa-bolt"></i>
</div>

<div class="logo-text">
<span class="logo-title">EBikes Duniya</span>
<span class="logo-sub">ELECTRIC · FREEDOM</span>
</div>

</a>


<!-- MENU -->

<div class="nav-menu" id="navMenu">

<a href="Home.aspx"><i class="fa fa-home"></i> Home</a>


<div class="dropdown">

<a href="Bikes.aspx">
<i class="fa fa-bolt bb"></i> Buy Bikes
</a>

<div class="dropdown-menu">

<a href="Bikes.aspx">New Bikes</a>
<a href="UsedBikes.aspx">Used Bikes</a>

</div>

</div>


<a href="SellBike.aspx"><i class="fa fa-tags"></i> Sell Bike</a>


<div class="dropdown">

<a href="Rental.aspx">
<i class="fa fa-motorcycle"></i> Rentals
</a>

<div class="dropdown-menu">

<a href="Rental.aspx">Browse Rentals</a>
<a href="MyRentals.aspx">My Rentals</a>

</div>

</div>


<a href="Compare.aspx"><i class="fa fa-balance-scale"></i> Compare</a>
<a href="Enquiry.aspx"><i class="fa fa-envelope"></i> Enquiry</a>

</div>


<!-- RIGHT -->

<div class="nav-actions">

<div class="icon-btn" onclick="toggleSearch()">
<i class="fa fa-search"></i>
</div>

<a href="Wishlist.aspx" class="icon-btn">

<i class="fa fa-heart"></i>

<span id="wishCount" runat="server" class="badge-count">0</span>

</a>


<asp:Panel ID="pnlLogin" runat="server">

<a href="ClientLogin.aspx" class="btn-login">
<i class="fa fa-user"></i> Sign In
</a>

</asp:Panel>


<asp:Panel ID="pnlUser" runat="server" Visible="false">

<a href="MyProfile.aspx" class="btn-login">

<asp:Label ID="lblUserName" runat="server"></asp:Label>

</a>

</asp:Panel>


<div class="menu-toggle" onclick="toggleMenu()">
<i class="fa fa-bars"></i>
</div>

</div>


<!-- SEARCH BOX -->

<div class="search-box" id="searchBox">

<input type="text" placeholder="Search bikes..."
onkeydown="if(event.key==='Enter'){window.location='Bikes.aspx?search='+this.value}" />

</div>


</div>

</nav>


<!-- ===== CONTENT ===== -->
<div class="main-content">
    <asp:ContentPlaceHolder ID="ContentPlaceHolder1"
        runat="server"></asp:ContentPlaceHolder>
</div>

<!-- ===== FOOTER ===== -->

<footer class="premium-footer">
<div class="container">

    <div class="footer-grid">

        <!-- Logo + About -->
        <div class="footer-col">
            <h4>EBikes Duniya</h4>
            <p>
                India’s trusted EV marketplace connecting buyers
                with verified dealers. Compare smartly and switch electric.
            </p>
        </div>

        <!-- Quick Links -->
        <div class="footer-col">
            <h5>Quick Links</h5>
            <ul>
                <li><a href="Bikes.aspx">Browse Bikes</a></li>
                <li><a href="Compare.aspx">Compare Bikes</a></li>
                <li><a href="Reviews.aspx">User Reviews</a></li>
                <li><a href="Contact.aspx">Contact Us</a></li>
            </ul>
        </div>

        <!-- Dealers -->
        <div class="footer-col">
            <h5>For Dealers</h5>
            <ul>
                <li><a href="DealerRegister.aspx">Become Dealer</a></li>
                <li><a href="DealerLogin.aspx">Dealer Login</a></li>
                <li><a href="#">Commission Policy</a></li>
            </ul>
        </div>

        <!-- Newsletter -->
        <div class="footer-col">
            <h5>Stay Updated</h5>
            <input type="email" placeholder="Enter your email" class="footer-input">
            <button class="footer-btn">Subscribe</button>
        </div>

    </div>

    <div class="footer-bottom">
        © 2026 EBikes Duniya. All rights reserved.
    </div>

</div>
</footer>


</form>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>

    function refreshWishlistCount() {

        $.ajax({
            type: "POST",
            url: "/Client/ClientMaster.master/GetWishlistCount",
            contentType: "application/json; charset=utf-8",
            dataType: "json",
            success: function (res) {

                $("#wishCount").text(res.d);

            }
        });

    }
    document.addEventListener("DOMContentLoaded", function () {

        var searchInput = document.getElementById("txtSearch");

        searchInput.addEventListener("keydown", function (e) {

            if (e.key === "Enter") {
                e.preventDefault();   // 🔥 refresh rokega
                doSearch();
            }

        });

    });

    function doSearch() {

        var keyword = document.getElementById("txtSearch").value.trim();

        if (keyword !== "") {
            window.location.href =
                "/Client/Bikes.aspx?search=" + encodeURIComponent(keyword);
        }
    }
</script>
  <script>

      function toggleMenu(){

          document.getElementById("navMenu")
          .classList.toggle("show");

      }


      function toggleSearch(){

          let box=document.getElementById("searchBox");

          if(box.style.display==="block")
              box.style.display="none";
          else
              box.style.display="block";

      }

</script>

</body>
</html>
